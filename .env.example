# WhatsApp Bridge Configuration
# ==============================

# Port for the Go bridge REST API
WHATSAPP_BRIDGE_PORT=8080

# Webhook URL for incoming messages (optional)
# Set this to forward incoming WhatsApp messages to another service
WEBHOOK_URL=http://localhost:8769/whatsapp/webhook

# Forward messages sent by self (true/false)
FORWARD_SELF=false


# MCP Server Configuration
# ========================

# Path to the SQLite messages database
# Default: relative path to whatsapp-bridge/store/messages.db
WHATSAPP_DB_PATH=./whatsapp-bridge/store/messages.db

# Path to whatsmeow's SQLite database (used to resolve LIDs ↔ phone numbers)
# Default: relative path to whatsapp-bridge/store/whatsapp.db
WHATSMEOW_DB_PATH=./whatsapp-bridge/store/whatsapp.db

# Go bridge REST API URL
WHATSAPP_API_URL=http://localhost:8080/api


# Docker / MCP Transport Configuration
# ======================================

# MCP transport used by the Python server (stdio | sse | streamable-http)
# Use "stdio" for Cursor / Claude Desktop (default)
# Use "sse" or "streamable-http" for a long-running HTTP daemon
MCP_TRANSPORT=streamable-http

# Bind host for HTTP transports (ignored in stdio mode)
MCP_HOST=0.0.0.0

# Listen port for HTTP transports (ignored in stdio mode)
MCP_PORT=8000

# Port for the pairing web UI served by the Go bridge
# Open http://localhost:WHATSAPP_UI_PORT in a browser to scan the QR code
WHATSAPP_UI_PORT=3000

# Path to the MCP tool-call statistics SQLite database
# Written by the Python MCP server, read by the Go UI server (Tools tab)
MCP_STATS_DB_PATH=./whatsapp-bridge/store/mcp_stats.db

# Path to the bearer-token file shared between the Go bridge (writes) and the
# Python MCP middleware (reads on every request). The file is created with
# mode 0600 on first start; rotate it from the pairing UI's "Connect" tab.
# stdio transport ignores this — only sse / streamable-http require auth.
MCP_AUTH_TOKEN_PATH=./whatsapp-bridge/store/auth_token
